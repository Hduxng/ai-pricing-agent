OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.5
OPENAI_SEARCH_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=low

DB_PATH=pricing.db

PRICE_FLOOR_PERCENT=0.85
PRICE_CEILING_PERCENT=1.30
MAX_DAILY_CHANGE_PERCENT=0.10
MIN_MARGIN_PERCENT=0.15
PRICE_ROUNDING=1000

REQUIRE_APPROVAL=true
DRY_RUN=true
CHECK_INTERVAL_HOURS=6
APP_TIMEZONE=Asia/Ho_Chi_Minh

WEBSITE_API_BASE_URL=https://your-website.com
WEBSITE_API_KEY=your_website_api_key

# Local web demo settings.
WEB_DEMO_HOST=127.0.0.1
WEB_DEMO_PORT=8000
WEB_DEMO_DB_PATH=pricing.db
DEMO_API_KEY=demo-secret

# Dify Workflow API. Keep the app key on the server; never put it in frontend JS.
DIFY_API_KEY=app-your_dify_workflow_api_key
DIFY_API_BASE_URL=https://api.dify.ai/v1
DIFY_USER=pricing-web-demo
DIFY_INPUT_NAME=products_json
DIFY_INPUT_FORMAT=json_string
DIFY_TIMEOUT=100

TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Optional: override SKUs from environment.
# TRACKED_SKUS_JSON=[{"sku":"SKU001","name":"Pin lithium 12V 100Ah","base_cost":2000000,"current_price":3200000}]
